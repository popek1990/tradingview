# ── Security ──────────────────────────────────────────────────────
# SEC_KEY — must match the "key" field in your TradingView alert JSON.
# Min 16 chars. Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SEC_KEY=your_secret_key_here

# DASHBOARD_PASSWORD — password to log into the admin panel (min 8 chars).
# If your password contains special characters (& $ ! # etc.), wrap it in single quotes.
DASHBOARD_PASSWORD='your_password_here'

# ── Telegram ──────────────────────────────────────────────────────
# Get token from @BotFather on Telegram (send /newbot).
# CHANNEL: add the bot to a group, then find the group ID in Dashboard → Channels.
SEND_ALERTS_TELEGRAM=True
TG_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
CHANNEL=-1001234567890
SEND_ALERTS_TELEGRAM_2=False
CHANNEL_2=

# ── Discord (optional) ───────────────────────────────────────────
# Get URL from: Discord → right-click channel → Edit Channel → Integrations → Webhooks → Copy URL
SEND_ALERTS_DISCORD=False
DISCORD_WEBHOOK=https://discord.com/api/webhooks/1234567890/abcdefg

# ── Slack (optional) ─────────────────────────────────────────────
# Get URL from: https://api.slack.com/apps → Incoming Webhooks → Add New Webhook
SEND_ALERTS_SLACK=False
SLACK_WEBHOOK=

# ── Advanced (optional) ──────────────────────────────────────────
# Trusted hosts — add your domain if using a reverse proxy (e.g. Cloudflare Tunnel).
# Leave commented out to use defaults (localhost, 127.0.0.1, webhook).
# ALLOWED_HOSTS=yourdomain.com,localhost,127.0.0.1,webhook,test,testserver
